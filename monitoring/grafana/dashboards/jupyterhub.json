{
  "title": "SAIEP - JupyterHub Monitoring",
  "uid": "saiep-jupyterhub",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Utilisateurs actifs (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "jupyterhub_active_users{period=\"24h\"}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Serveurs utilisateurs en cours",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "jupyterhub_running_servers", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Total utilisateurs",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "jupyterhub_total_users", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Hub joignable",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "up{job=\"jupyterhub\"}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Requetes HTTP par code de statut",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(jupyterhub_request_duration_seconds_count[5m])) by (code)",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Duree de demarrage des serveurs (p95)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(jupyterhub_server_spawn_duration_seconds_bucket[10m])) by (le))",
          "legendFormat": "p95 spawn",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Latence des requetes hub (p95)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(jupyterhub_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latence",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Echecs de demarrage de serveurs",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "sum(rate(jupyterhub_server_spawn_duration_seconds_count{status!=\"success\"}[10m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
