GF_SERVER_ROOT_URL=https://104.248.22.193.sslip.io/services/monitoring/
GF_SERVER_SERVE_FROM_SUB_PATH=true
GF_USERS_ALLOW_SIGN_UP=false

# Local fallback admin — must NOT collide with any JupyterHub SSO username.
GF_SECURITY_ADMIN_USER=saiepadmin
GF_SECURITY_ADMIN_PASSWORD=replace-with-a-strong-password

# --- Single Sign-On: JupyterHub is the OAuth identity provider ---
GF_AUTH_GENERIC_OAUTH_ENABLED=true
GF_AUTH_GENERIC_OAUTH_NAME=ESTIN SAIEP
GF_AUTH_GENERIC_OAUTH_ALLOW_SIGN_UP=true
GF_AUTH_GENERIC_OAUTH_CLIENT_ID=service-monitoring
# Must equal SAIEP_MONITORING_TOKEN from secrets.env
GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET=replace-with-SAIEP_MONITORING_TOKEN
GF_AUTH_GENERIC_OAUTH_SCOPES=
GF_AUTH_GENERIC_OAUTH_EMPTY_SCOPES=true
GF_AUTH_GENERIC_OAUTH_AUTH_URL=https://104.248.22.193.sslip.io/hub/api/oauth2/authorize
GF_AUTH_GENERIC_OAUTH_TOKEN_URL=http://172.17.0.1:8000/hub/api/oauth2/token
GF_AUTH_GENERIC_OAUTH_API_URL=http://172.17.0.1:8000/hub/api/user
GF_AUTH_GENERIC_OAUTH_LOGIN_ATTRIBUTE_PATH=name
GF_AUTH_GENERIC_OAUTH_NAME_ATTRIBUTE_PATH=name
# JupyterHub userinfo has no email; map it from username to avoid the /emails 404.
GF_AUTH_GENERIC_OAUTH_EMAIL_ATTRIBUTE_PATH=name
GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH=contains(['r4y4n3','litan'], name) && 'Admin' || 'Viewer'
GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_STRICT=false
GF_AUTH_GENERIC_OAUTH_USE_PKCE=true
