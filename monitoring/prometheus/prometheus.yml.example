global:
  scrape_interval: 30s
  evaluation_interval: 30s

scrape_configs:
  - job_name: jupyterhub
    metrics_path: /hub/metrics
    static_configs:
      - targets: ['172.17.0.1:8000']
    authorization:
      type: Bearer
      # Must equal SAIEP_PROMETHEUS_TOKEN from secrets.env
      credentials: replace-with-SAIEP_PROMETHEUS_TOKEN

  - job_name: prometheus
    static_configs:
      - targets: ['127.0.0.1:9090']
