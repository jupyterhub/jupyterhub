# Free automatic HTTPS for JupyterHub via Caddy + Let's Encrypt.
# Domain is a free sslip.io name that resolves to this VPS public IP.
# Port 80 is occupied on this host, so we disable the HTTP redirect and
# let Caddy obtain certs over TLS-ALPN-01 on port 443 only.
{
	auto_https disable_redirects
	http_port 8080
	email r_boucheraine@estin.dz
}

104.248.22.193.sslip.io {
	# Tout passe par JupyterHub. Grafana est intégré et servi par le hub
	# lui-même sous /services/monitoring (SSO JupyterHub) — il n'est plus
	# exposé en direct.
	reverse_proxy 172.17.0.1:8000
}

# Espace super-admin des ressources : Portainer (voir / ajouter / supprimer
# les ressources et conteneurs). Sous-domaine dédié, login Portainer propre.
portainer.104.248.22.193.sslip.io {
	reverse_proxy 127.0.0.1:9000
}
